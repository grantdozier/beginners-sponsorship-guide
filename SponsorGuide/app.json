{
  "expo": {
    "name": "Beginners Sponsorship Guide",
    "slug": "beginners-sponsorship-guide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF1DE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.grantdozier.sponsorguide",
      "buildNumber": "3",
      "appleTeamId": "67NB48YDBQ",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.grantdozier.sponsorguide",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF1DE"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-font",
      "expo-secure-store",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "c02a011f-0f1e-4a96-9d4c-badb0a5a5735"
      }
    },
    "owner": "grantdozier"
  }
}
